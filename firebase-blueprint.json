{
  "entities": {
    "Comment": {
      "title": "Comment",
      "description": "A user comment on the website",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the commenter"
        },
        "message": {
          "type": "string",
          "description": "The content of the comment"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the comment was created"
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether the comment is pinned by the admin"
        }
      },
      "required": ["name", "message", "createdAt"]
    }
  },
  "firestore": {
    "/comments/{commentId}": {
      "schema": {
        "$ref": "#/entities/Comment"
      },
      "description": "Stores all public comments"
    }
  }
}
